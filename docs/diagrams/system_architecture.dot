digraph G {
    rankdir=LR;
    subgraph cluster_presentation {
        label = "Presentation Layer";
        style = rounded;
        UI [label="Streamlit Web App"];
    }
    subgraph cluster_logic {
        label = "Application Logic Layer";
        style = rounded;
        HE [label="Heuristic Engine"];
    }
    subgraph cluster_data {
        label = "Data Layer";
        style = rounded;
        DB [label="SQLite DB", shape=folder];
    }
    UI -> HE [dir=both];
    HE -> DB [dir=both];
}
